<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Instagram</title>
</head>
<body>
    <h3>This page belongs to @<%= username %></h3>
    <button>Follow</button>
    <button>Message</button>

    <h4>Followers:</h4>
    <ul>
        <% followers.forEach(follower => { %>
            <li><%= follower %></li>
        <% }); %>
    </ul>
</body>
</html>